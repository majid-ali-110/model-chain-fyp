@startuml ModelChain Use Case Diagram

' Title and Styling
title ModelChain - Decentralized AI Model Marketplace\nSystem Overview

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor white

' Actors
actor "Visitor\n(Unconnected)" as Visitor
actor "User\n(Wallet Connected)" as User
actor "Developer\n(Model Creator)" as Developer
actor "Validator\n(Quality Checker)" as Validator
actor "Admin\n(Platform Manager)" as Admin
actor "DAO Member\n(Token Holder)" as DAO

' External Systems
actor "MetaMask\nWallet" as MetaMask <<External>>
actor "IPFS/Pinata\nStorage" as IPFS <<External>>
actor "Smart Contract\nBlockchain" as Blockchain <<External>>

' ============================================
' MAIN PACKAGES
' ============================================
package "Authentication & Wallet Management" as Auth {
}

package "Marketplace & Model Discovery" as Marketplace {
}

package "Sandbox & Model Testing" as Sandbox {
}

package "User Profile & Dashboard" as UserDash {
}

package "Developer - Model Management" as DevMgmt {
}

package "Validator - Quality Assurance" as ValidatorQA {
}

package "Governance & DAO" as Governance {
}

package "Admin - Platform Management" as AdminMgmt {
}

package "Documentation & Support" as Docs {
}

' ============================================
' RELATIONSHIPS
' ============================================
Visitor --> Auth
Visitor --> Marketplace : Browse
Visitor --> Docs

User --> Auth
User --> Marketplace
User --> Sandbox
User --> UserDash

Developer --|> User : inherits
Developer --> DevMgmt
Developer --> Marketplace

Validator --|> User : inherits
Validator --> ValidatorQA

DAO --|> User : inherits
DAO --> Governance

Admin --|> User : inherits
Admin --> AdminMgmt

' External System Connections
Auth ..> MetaMask : <<uses>>
Auth ..> Blockchain : <<verifies>>
Marketplace ..> Blockchain : <<transactions>>
Marketplace ..> IPFS : <<storage>>
DevMgmt ..> IPFS : <<uploads>>
DevMgmt ..> Blockchain : <<mints NFT>>
ValidatorQA ..> IPFS : <<downloads>>
ValidatorQA ..> Blockchain : <<records>>
Governance ..> Blockchain : <<voting>>
AdminMgmt ..> Blockchain : <<management>>

' ============================================
' NOTES
' ============================================
note right of Visitor
  Can browse marketplace
  but needs wallet to
  purchase or interact
end note

note right of User
  Basic authenticated user
  Can purchase models,
  test in sandbox, and
  participate in governance
end note

note right of Developer
  Can upload and manage
  AI models, track analytics,
  and earn from sales
end note

note right of Validator
  Validates model quality,
  earns rewards for
  accurate validations
end note

note right of Admin
  Platform administrator
  with full management
  capabilities
end note

note right of DAO
  Token holders can
  create and vote on
  governance proposals
end note

note bottom of Blockchain
  Polygon Amoy Testnet
  Contracts:
  - UserRegistry: 0x88B0...0b0D
  - ModelRegistry: 0x276B...a5AC
  - Marketplace: 0x7e77...0b91
  - Governance: 0xfD19...e0AE
end note

note bottom of IPFS
  Pinata Service
  Stores:
  - Model files
  - Model metadata
  - User profiles
end note

@enduml
