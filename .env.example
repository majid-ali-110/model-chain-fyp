# ──────────────────────────────────────────────────────────────────────────
# ModelChain environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# ===========================================================================
# CLIENT (VITE_*) — bundled into the public browser build.
# Set these in the Vercel dashboard (Production + Preview).
# WARNING: anything prefixed VITE_ is PUBLICLY VISIBLE in the shipped JS.
#          Never put a real wallet/deployer key behind a VITE_ name.
# ===========================================================================

# Pinata IPFS uploads. Prefer a scoped JWT (pinning-only) over api+secret,
# since the api/secret pair is fully readable by anyone visiting the site.
# Get one at https://app.pinata.cloud/  (Developers -> API Keys)
VITE_PINATA_JWT=

# Legacy Pinata auth (used only if VITE_PINATA_JWT is empty):
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET_KEY=

# Base URL of the hosted inference server (Flask). Leave empty for now —
# the model sandbox is disabled until this points at a deployed server.
# In local dev, leave empty: Vite proxies /api/inference to 127.0.0.1:8000.
# In production, set e.g. https://your-inference.onrender.com
VITE_INFERENCE_API_BASE=

# Optional: default model path passed to the inference server.
VITE_SANDBOX_MODEL_PATH=

# ===========================================================================
# HARDHAT / DEPLOY-ONLY — used by scripts on your machine, NOT by the frontend.
# DO NOT add these to Vercel. Keep them only in your local `.env`.
# ===========================================================================

# RPC endpoint for deploying/verifying contracts (Polygon Amoy testnet).
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Infura key (optional, for other networks).
INFURA_KEY=

# Deployer private key. NEVER commit a real key. NEVER expose via VITE_*.
PRIVATE_KEY=
